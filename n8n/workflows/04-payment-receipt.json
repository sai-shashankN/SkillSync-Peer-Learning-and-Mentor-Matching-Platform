{
    "name": "Payment Receipt",
    "nodes": [
        {
            "id": "1",
            "name": "Payment Received Webhook",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 2.1,
            "position": [
                260,
                280
            ],
            "parameters": {
                "httpMethod": "POST",
                "path": "payment-received",
                "responseMode": "onReceived"
            }
        },
        {
            "id": "2",
            "name": "Normalize Payload",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                500,
                280
            ],
            "parameters": {
                "functionCode": "return items.map((item) => ({ json: item.json.body ?? item.json }));"
            }
        },
        {
            "id": "3",
            "name": "Fetch Payer User",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.4,
            "position": [
                740,
                280
            ],
            "parameters": {
                "method": "GET",
                "url": "=http://host.docker.internal:8082/users/internal/{{$node['Normalize Payload'].json.payerId}}",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "X-Internal-Service-Token",
                            "value": "={{$env.INTERNAL_SERVICE_TOKEN}}"
                        }
                    ]
                }
            }
        },
        {
            "id": "4",
            "name": "Send Receipt Email",
            "type": "n8n-nodes-resend.resend",
            "typeVersion": 1,
            "position": [
                980,
                280
            ],
            "parameters": {
                "resource": "email",
                "operation": "send",
                "from": "SkillSync <noreply@saishashank.dev>",
                "to": "={{$json.data?.email || $node[\"Normalize Payload\"].json.payerEmail}}",
                "subject": "SkillSync payment receipt",
                "useTemplate": false,
                "emailFormat": "both",
                "html": "={{`<div><h1>Payment received</h1><p>We have received your payment for SkillSync.</p><p>Payment ID: ${$node[\"Normalize Payload\"].json.paymentId ?? \"N/A\"}</p><p>Session ID: ${$node[\"Normalize Payload\"].json.sessionId ?? \"N/A\"}</p></div>`}}",
                "text": "={{`We have received your payment for SkillSync. Payment ID: ${$node[\"Normalize Payload\"].json.paymentId ?? \"N/A\"}. Session ID: ${$node[\"Normalize Payload\"].json.sessionId ?? \"N/A\"}.`}}",
                "additionalOptions": {}
            },
            "credentials": {
                "resendApi": {
                    "id": "YAify4P98jQAJrnR",
                    "name": "SkillSync Resend API"
                }
            }
        }
    ],
    "connections": {
        "Payment Received Webhook": {
            "main": [
                [
                    {
                        "node": "Normalize Payload",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Normalize Payload": {
            "main": [
                [
                    {
                        "node": "Fetch Payer User",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Fetch Payer User": {
            "main": [
                [
                    {
                        "node": "Send Receipt Email",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "active": false,
    "settings": {
        "executionOrder": "v1"
    },
    "tags": [
        {
            "name": "skillsync"
        }
    ]
}
